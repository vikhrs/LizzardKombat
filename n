<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Buzzamix</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="/socket.io/socket.io.js"></script>
    <style>
        /* === LIQUID GLASS & NEON CYAN THEME === */
        :root { 
            --bg-color: #050a15;
            --bg-gradient: radial-gradient(circle at 50% 0%, #0a1931 0%, #000000 100%);
            --text: #ffffff; 
            --panel: rgba(10, 20, 35, 0.6); 
            --border: rgba(0, 229, 255, 0.25); 
            --accent: #00e5ff; 
            --accent-glow: rgba(0, 229, 255, 0.6);
            --gold: #ffd700; 
            --red: #ff3333; 
            --glass-blur: blur(20px);
            --glass-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.8);
        }
        
        body { 
            background-color: var(--bg-color); background-image: var(--bg-gradient);
            background-attachment: fixed; color: var(--text); 
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; 
            margin: 0; padding: 0; overflow: hidden; height: 100vh; display: flex; flex-direction: column;
        }
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        .hidden { display: none !important; }

        .glass {
            background: var(--panel); backdrop-filter: var(--glass-blur); -webkit-backdrop-filter: var(--glass-blur);
            border: 1px solid var(--border); box-shadow: var(--glass-shadow);
        }
        
        header { 
            flex-shrink: 0; z-index: 50; display: flex; justify-content: space-between; align-items: center; 
            padding: 15px 20px; border-bottom: 1px solid var(--border);
        }
        .header-title { font-size: 1.4em; color: var(--accent); text-shadow: 0 0 10px var(--accent-glow); font-weight: 800; letter-spacing: 1px;}

        .nav-bar { 
            flex-shrink: 0; height: 70px; display: flex; justify-content: space-around;
            padding-bottom: env(safe-area-inset-bottom, 0px); border-top: 1px solid var(--border); z-index: 50;
        }
        .nav-btn { flex: 1; text-align: center; cursor: pointer; color: #888; display: flex; flex-direction: column; align-items: center; justify-content: center; transition: 0.3s; }
        .nav-btn.active { color: var(--accent); transform: translateY(-3px); }
        .nav-btn i { font-size: 20px; }
        .nav-btn span { font-size: 10px; margin-top: 4px; font-weight: 600; }

        .screen { flex: 1; overflow-y: auto; padding: 15px; animation: fadeIn 0.4s ease; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        input, textarea, select { 
            width: 100%; padding: 14px; margin-bottom: 12px; background: rgba(0,0,0,0.4); color: var(--text); 
            border: 1px solid var(--border); border-radius: 12px; font-size: 16px; outline: none;
        }
        .btn { 
            width: 100%; padding: 15px; background: var(--accent); color: #000; border: none; border-radius: 12px; 
            font-weight: bold; cursor: pointer; transition: 0.3s;
        }
        .btn-gold { background: var(--gold); }
        .btn-outline { background: transparent; color: var(--text); border: 1px solid var(--border); }

        .post-card { border-radius: 18px; padding: 18px; margin-bottom: 15px; border: 1px solid rgba(255,255,255,0.1); }
        .avatar-img { width: 45px; height: 45px; border-radius: 50%; object-fit: cover; border: 2px solid var(--accent); }
        
        #sidebar { 
            position: fixed; top:0; left:0; width:280px; height:100%; z-index:1000; 
            transform: translateX(-100%); transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); padding: 25px 20px;
        }
        #sidebar.open { transform: translateX(0); }
        #sidebar-overlay { position: fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.7); z-index:900; }

        .account-item { display:flex; align-items:center; padding:12px; margin-bottom:10px; border-radius:12px; border:1px solid var(--border); cursor:pointer; }
        .active-acc { border-color: var(--accent); box-shadow: 0 0 10px var(--accent-glow); }

        .badge { padding: 2px 6px; border-radius: 6px; font-size: 10px; margin-left: 5px; vertical-align: middle; }
        .badge-blue { background: #00a8ff; } .badge-gold { background: var(--gold); color: #000; }
    </style>
</head>
<body>

<div id="alert-modal" class="modal-overlay hidden" style="position:fixed; z-index:10000; width:100%; height:100%; background:rgba(0,0,0,0.8); display:flex; align-items:center; justify-content:center;">
    <div class="modal-box glass" style="padding:30px; border-radius:20px; text-align:center; width:80%;">
        <h3 id="alert-title" style="color:var(--accent);"></h3>
        <p id="alert-text"></p>
        <button class="btn" onclick="UI.closeAlert()">Понятно</button>
    </div>
</div>

<div id="sidebar-overlay" class="hidden" onclick="App.toggleSidebar()"></div>
<div id="sidebar" class="glass">
    <h3 style="color:var(--accent); margin-bottom:5px;">Buzzamix Menu</h3>
    <p style="font-size:12px; color:gray; margin-bottom:20px;">v.2.0 Stable</p>
    
    <div style="margin-bottom: 25px; background:rgba(0,229,255,0.1); padding:10px; border-radius:10px;">
        <span style="font-size:10px; color:var(--accent); display:block;">OFFICIAL CHANNEL:</span>
        <b style="cursor:pointer;" onclick="App.handleMention('buzzamix')">@buzzamix</b>
    </div>

    <div id="accounts-list"></div>
    
    <button class="btn btn-outline" style="margin-top:15px;" onclick="App.showAuthScreen(true)"><i class="fa-solid fa-user-plus"></i> Добавить аккаунт</button>
    <button class="btn btn-outline" style="margin-top:10px; color:var(--red); border-color:var(--red);" onclick="App.logout()"><i class="fa-solid fa-sign-out"></i> Выйти</button>
</div>

<div id="scr-auth" class="screen hidden" style="display:flex; align-items:center; justify-content:center;">
    <div class="glass" style="padding:30px; border-radius:25px; width:100%; max-width:350px;">
        <h1 style="text-align:center; color:var(--accent); margin-bottom:20px;">Buzzamix</h1>
        <div id="auth-forms">
            <input id="auth-u" placeholder="Юзернейм">
            <input id="auth-p" type="password" placeholder="Пароль">
            <button class="btn" onclick="App.handleAuth()">Войти / Регистрация</button>
        </div>
    </div>
</div>

<div id="main-app" class="hidden">
    <header class="glass">
        <i class="fa-solid fa-bars" style="font-size:20px; cursor:pointer;" onclick="App.toggleSidebar()"></i>
        <div class="header-title">BUZZAMIX</div>
        <i class="fa-solid fa-search" onclick="App.nav('search')"></i>
    </header>

    <div id="scr-feed" class="screen">
        <div id="feed-container"></div>
        <div style="height:80px;"></div>
    </div>

    <div id="scr-chats" class="screen hidden">
        <div id="chats-list"></div>
    </div>

    <div id="scr-ai" class="screen hidden">
        <div id="ai-messages" style="height:70vh; overflow-y:auto; padding-bottom:20px;"></div>
        <div style="display:flex; gap:10px;">
            <input id="ai-input" placeholder="Спроси Gemini..." style="margin:0;">
            <button class="btn" style="width:60px;" onclick="App.askAI()"><i class="fa-solid fa-paper-plane"></i></button>
        </div>
    </div>

    <div id="scr-store" class="screen hidden">
        <h2 style="text-align:center;">Магазин BIZI</h2>
        <div class="post-card glass">
            <h3>Premium Gold</h3>
            <p>Безлимитный ИИ + Золотая галочка</p>
            <p>Цена: 500 BIZI</p>
            <button class="btn btn-gold" onclick="App.buyPremium('gold')">Купить Gold</button>
        </div>
        <div class="post-card glass">
            <h3>Premium Blue</h3>
            <p>Улучшенный ИИ + Синяя галочка</p>
            <p>Цена: 100 BIZI</p>
            <button class="btn" onclick="App.buyPremium('blue')">Купить Blue</button>
        </div>
    </div>

    <div id="scr-profile" class="screen hidden">
        <div id="profile-content" style="text-align:center;"></div>
        <div id="user-posts"></div>
    </div>

    <nav class="nav-bar glass">
        <div class="nav-btn active" onclick="App.nav('feed')"><i class="fa-solid fa-house"></i><span>Лента</span></div>
        <div class="nav-btn" onclick="App.nav('chats')"><i class="fa-solid fa-message"></i><span>Чаты</span></div>
        <div class="nav-btn" onclick="App.nav('ai')"><i class="fa-solid fa-robot"></i><span>Gemini</span></div>
        <div class="nav-btn" onclick="App.nav('store')"><i class="fa-solid fa-shop"></i><span>Магазин</span></div>
        <div class="nav-btn" onclick="App.viewUser(App.me)"><i class="fa-solid fa-user"></i><span>Профиль</span></div>
    </nav>
</div>

<div id="fab-post" class="glass" style="position:fixed; bottom:90px; right:20px; width:60px; height:60px; border-radius:50%; display:flex; align-items:center; justify-content:center; color:var(--accent); font-size:24px; cursor:pointer; z-index:100;" onclick="App.openCreatePost()">
    <i class="fa-solid fa-plus"></i>
</div>

<script>
/**
 * БЛОК ЛОГИКИ ПРИЛОЖЕНИЯ
 */
const socket = io(); // Подключение к серверу

const UI = {
    alert: (title, text) => {
        document.getElementById('alert-title').innerText = title;
        document.getElementById('alert-text').innerText = text;
        document.getElementById('alert-modal').classList.remove('hidden');
    },
    closeAlert: () => document.getElementById('alert-modal').classList.add('hidden')
};

const App = {
    me: localStorage.getItem('bz_current_user'),
    accounts: JSON.parse(localStorage.getItem('bz_accounts') || "[]"),
    users: {}, // Сюда придут данные с сервера
    posts: [],
    
    async init() {
        if (!this.me) {
            this.showAuthScreen();
        } else {
            this.showMain();
            this.syncData(); // Первая синхронизация
        }
        
        // Автообновление каждую секунду для имитации реального времени
        setInterval(() => this.syncData(), 2000);

        // Слушаем входящие данные от сервера
        socket.on('update_data', (data) => {
            this.users = data.users;
            this.posts = data.posts;
            this.render();
        });
    },

    syncData() {
        socket.emit('request_sync', { user: this.me });
    },

    showAuthScreen() {
        document.getElementById('scr-auth').classList.remove('hidden');
        document.getElementById('main-app').classList.add('hidden');
    },

    showMain() {
        document.getElementById('scr-auth').classList.add('hidden');
        document.getElementById('main-app').classList.remove('hidden');
        this.nav('feed');
    },

    handleAuth() {
        const u = document.getElementById('auth-u').value.trim().toLowerCase();
        const p = document.getElementById('auth-p').value;
        if (!u || !p) return UI.alert("Ошибка", "Заполните поля");

        // Отправляем на сервер запрос на регистрацию/вход
        socket.emit('auth_user', { username: u, password: p });
        
        socket.once('auth_success', (userData) => {
            this.me = u;
            if (!this.accounts.includes(u)) this.accounts.push(u);
            localStorage.setItem('bz_current_user', u);
            localStorage.setItem('bz_accounts', JSON.stringify(this.accounts));
            this.showMain();
        });
    },

    logout() {
        this.accounts = this.accounts.filter(a => a !== this.me);
        localStorage.setItem('bz_accounts', JSON.stringify(this.accounts));
        this.me = this.accounts[0] || null;
        localStorage.setItem('bz_current_user', this.me || '');
        location.reload();
    },

    toggleSidebar() {
        const sb = document.getElementById('sidebar');
        const ov = document.getElementById('sidebar-overlay');
        sb.classList.toggle('open');
        ov.classList.toggle('hidden');
        this.renderAccounts();
    },

    renderAccounts() {
        const list = document.getElementById('accounts-list');
        list.innerHTML = this.accounts.map(acc => `
            <div class="account-item ${acc === this.me ? 'active-acc' : ''}" onclick="App.switchAccount('${acc}')">
                <i class="fa-solid fa-circle-user" style="margin-right:10px;"></i>
                <span>@${acc}</span>
            </div>
        `).join('');
    },

    switchAccount(acc) {
        this.me = acc;
        localStorage.setItem('bz_current_user', acc);
        this.toggleSidebar();
        this.syncData();
    },

    nav(screen) {
        document.querySelectorAll('.screen').forEach(s => s.classList.add('hidden'));
        document.getElementById('scr-' + screen).classList.remove('hidden');
        document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
        // Скролл вверх при переключении
        document.getElementById('scr-' + screen).scrollTop = 0;
        this.render();
    },

    // АЛГОРИТМ РЕКОМЕНДАЦИЙ (Умная лента)
    getRecommendedPosts() {
        return [...this.posts].sort((a, b) => {
            // Вес: лайки дают +10 очков, новизна +5, рандом +2
            const scoreA = (a.likes || 0) * 10 + (a.timestamp / 1000000);
            const scoreB = (b.likes || 0) * 10 + (b.timestamp / 1000000);
            return scoreB - scoreA;
        });
    },

    render() {
        const feed = document.getElementById('feed-container');
        if (!feed) return;

        const recs = this.getRecommendedPosts();
        feed.innerHTML = recs.map(p => {
            const user = this.users[p.author] || { username: p.author };
            return `
                <div class="post-card glass">
                    <div style="display:flex; align-items:center; gap:10px; margin-bottom:10px;" onclick="App.viewUser('${p.author}')">
                        <div class="avatar-img" style="background:#222; display:flex; align-items:center; justify-content:center;">
                            <i class="fa-solid fa-user"></i>
                        </div>
                        <div>
                            <b>@${p.author}</b> ${this.getBadge(user)}
                            <div style="font-size:10px; color:gray;">Рекомендовано вам</div>
                        </div>
                    </div>
                    <div style="font-size:15px; line-height:1.5;">${p.text}</div>
                    <div style="margin-top:12px; color:var(--accent);" onclick="App.likePost('${p.id}')">
                        <i class="fa-solid fa-heart"></i> ${p.likes || 0}
                    </div>
                </div>
            `;
        }).join('');
    },

    getBadge(user) {
        if (user.premium === 'gold') return `<span class="badge badge-gold"><i class="fa-solid fa-check"></i></span>`;
        if (user.premium === 'blue') return `<span class="badge badge-blue"><i class="fa-solid fa-check"></i></span>`;
        return '';
    },

    openCreatePost() {
        const txt = prompt("О чем вы думаете?");
        if (txt) {
            socket.emit('new_post', { author: this.me, text: txt, timestamp: Date.now() });
        }
    },

    buyPremium(type) {
        const user = this.users[this.me];
        if (user.premium === 'gold') return UI.alert("Ошибка", "У вас уже максимальный уровень Premium!");
        if (user.premium === 'blue' && type === 'blue') return UI.alert("Ошибка", "У вас уже активен этот статус");

        socket.emit('buy_premium', { user: this.me, type: type });
        UI.alert("Успех", "Запрос отправлен. Если BIZI достаточно, статус обновится.");
    },

    async askAI() {
        const input = document.getElementById('ai-input');
        const chat = document.getElementById('ai-messages');
        const text = input.value;
        if (!text) return;

        chat.innerHTML += `<p style="text-align:right;"><b>Вы:</b> ${text}</p>`;
        input.value = "";

        try {
            const res = await fetch("https://generativelanguage.googleapis.com/v1beta/models/gemini-flash-latest:generateContent?key=AIzaSyCW6dYv4z21a8XRAh9Ca_8INaXirbMl01s", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ contents: [{ parts: [{ text: text }] }] })
            });
            const data = await res.json();
            const reply = data.candidates[0].content.parts[0].text;
            chat.innerHTML += `<p style="background:rgba(0,229,255,0.1); padding:10px; border-radius:10px;"><b>Gemini:</b> ${reply}</p>`;
            chat.scrollTop = chat.scrollHeight;
        } catch (e) {
            UI.alert("Ошибка ИИ", "Проверьте интернет или лимит запросов.");
        }
    },

    viewUser(username) {
        this.nav('profile');
        const container = document.getElementById('profile-content');
        const user = this.users[username] || { username: username, balance: 0 };
        container.innerHTML = `
            <div style="font-size:50px; margin:20px 0;"><i class="fa-solid fa-circle-user"></i></div>
            <h2>@${username} ${this.getBadge(user)}</h2>
            <p>Баланс: ${user.balance || 0} BIZI</p>
            <hr style="border:0; border-top:1px solid var(--border); margin:20px 0;">
        `;
    }
};

window.onload = () => App.init();

// Offline support (Service Worker simple mock)
if ('serviceWorker' in navigator) {
    console.log("Buzzamix Offline Mode Ready");
}
</script>
</body>
</html>
